{
  "name": "softdraw-desktop",
  "version": "1.0.0",
  "description": "SoftDraw Screen Pen — draw over anything on your screen (Epic Pen style).",
  "main": "main.cjs",
  "author": "SoftDraw",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env SCREEN_URL=http://localhost:3000/screen electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "site.softdraw.desktop",
    "productName": "SoftDraw Screen Pen",
    "files": ["main.cjs", "icon.png"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": { "target": "dmg", "icon": "icon.png" },
    "linux": { "target": "AppImage", "icon": "icon.png" }
  }
}
